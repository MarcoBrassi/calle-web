---
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import "../styles/global.scss";

const { activePage, hideFooter = false } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Calle</title>
	</head>

	<body>
		<Header activePage={activePage} isHome={activePage === "home"}/>

		<main>
			<slot />
		</main>

		{!hideFooter && <Footer />}
	</body>
</html>
