---
import { sanityClient } from 'sanity:client'
import Layout from '../../layouts/Layout.astro'
import Gallery2Col from '../../components/galleries/gallery_2col.astro'
import Gallery4Col from '../../components/galleries/gallery_4col.astro'
import GalleryMosaic from '../../components/galleries/gallery_mosaic.astro'

type GalleryItem = {
    type: 'image' | 'video'
    src: string
    alt?: string
    size?: 'small' | 'medium' | 'large' | 'normal' | 'tall' | 'wide'
}

type GalleryBlock = {
    blockType: 'stackedFull' | 'threeColumns' | 'dynamicTwoColumns' | 'fullWidth' | 'squareTwoColumns'
    title?: string
    items?: GalleryItem[]
}

type Project = {
    title: string
    campaign?: string
    slug: string
    services?: string[]
    description?: string
    layout?: 'twoColumns' | 'fourColumns' | 'mosaic'
    coverMedia?: GalleryItem
    gallery?: GalleryItem[]
    galleryBlocks?: GalleryBlock[]
}

export async function getStaticPaths() {
    const projects = await sanityClient.fetch<Project[]>(`
        *[_type == "project" && defined(slug.current)] | order(order asc) {
            title,
            campaign,
            "slug": slug.current,
            services,
            description,
            layout,
            "coverMedia": select(
                coverMedia.mediaType == "video" && defined(coverMedia.video.asset) => {
                    "type": "video",
                    "src": coverMedia.video.asset->url,
                    "alt": title
                },
                coverMedia.mediaType == "image" && defined(coverMedia.image.asset) => {
                    "type": "image",
                    "src": coverMedia.image.asset->url,
                    "alt": title
                },
                defined(coverImage.asset) => {
                    "type": "image",
                    "src": coverImage.asset->url,
                    "alt": title
                }
            ),
            gallery[] {
                "type": "image",
                "src": image.asset->url,
                alt,
                size
            },
            galleryBlocks[] {
                blockType,
                title,
                items[] {
                    "type": mediaType,
                    "src": select(
                        mediaType == "video" => video.asset->url,
                        image.asset->url
                    ),
                    alt,
                    size
                }
            }
        }
    `)

    return projects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
    }))
}

const { project } = Astro.props as { project: Project }
const coverMedia = project.coverMedia?.src
    ? [project.coverMedia]
    : []
const galleryWithoutCover = project.gallery?.filter((item) =>
    item.src && item.src !== project.coverMedia?.src
) ?? []
const galleryItems = [
    ...coverMedia,
    ...galleryWithoutCover,
]
---

<Layout activePage="projects">
    {
        project.layout === 'mosaic' ? (
            <GalleryMosaic
                blocks={project.galleryBlocks}
                title={project.title}
                campaign={project.campaign}
                services={project.services}
                description={project.description}
            />
        ) : project.layout === 'fourColumns' ? (
            <Gallery4Col
                items={galleryItems}
                title={project.title}
                campaign={project.campaign}
                services={project.services}
                description={project.description}
            />
        ) : (
            <Gallery2Col
                items={galleryItems}
                title={project.title}
                campaign={project.campaign}
                services={project.services}
                description={project.description}
            />
        )
    }
</Layout>

<script>
    const projectInfo = document.querySelector<HTMLElement>(".project-info--overlay");
    const projectGallery = projectInfo?.closest<HTMLElement>(".gallery2col, .gallery4col, .gallery-mosaic");
    const footer = document.querySelector<HTMLElement>("footer");

    if (projectInfo && projectGallery) {
        const syncProjectInfoHeight = () => {
            projectGallery.style.setProperty("--project-info-height", `${projectInfo.offsetHeight}px`);
        };

        syncProjectInfoHeight();
        window.addEventListener("resize", syncProjectInfoHeight);

        if ("ResizeObserver" in window) {
            const resizeObserver = new ResizeObserver(syncProjectInfoHeight);
            resizeObserver.observe(projectInfo);
        }
    }

    if (projectInfo && footer && "IntersectionObserver" in window) {
        const footerObserver = new IntersectionObserver(
            ([entry]) => {
                projectInfo.classList.toggle("project-info--docked", entry.isIntersecting);
            },
            {
                threshold: 0,
            },
        );

        footerObserver.observe(footer);
    }
</script>
