---
import { sanityClient } from 'sanity:client'
import Layout from "../layouts/Layout.astro";
import HeroSlider from "../components/HeroSlider.astro";

type HeroSlide = {
	layout: 'full' | 'split'
	image?: {
		src?: string
		alt?: string
	}
	secondImage?: {
		src?: string
		alt?: string
	}
}

type SlideGroup = {
	title?: string
	isMain?: boolean
	slides?: HeroSlide[]
}

type HomeSliderDocument = {
	title?: string
	isMain?: boolean
	slides?: HeroSlide[]
	heroSlides?: HeroSlide[]
	slideGroups?: SlideGroup[]
}

const homeSliderDocuments = await sanityClient.fetch<HomeSliderDocument[]>(`
	*[_type == "homeSettings"] | order(_createdAt asc) {
		title,
		isMain,
		slides[] {
			layout,
			"image": {
				"src": image.asset->url,
				"alt": coalesce(alt, "Imagen de portada")
			},
			"secondImage": select(
				layout == "split" => {
					"src": secondImage.asset->url,
					"alt": coalesce(secondAlt, "Imagen de portada")
				}
			)
		},
		slideGroups[] {
			title,
			isMain,
			slides[] {
				layout,
				"image": {
					"src": image.asset->url,
					"alt": coalesce(alt, "Imagen de portada")
				},
				"secondImage": select(
					layout == "split" => {
						"src": secondImage.asset->url,
						"alt": coalesce(secondAlt, "Imagen de portada")
					}
				)
			}
		},
		heroSlides[] {
			layout,
			"image": {
				"src": image.asset->url,
				"alt": coalesce(alt, "Imagen de portada")
			},
			"secondImage": select(
				layout == "split" => {
					"src": secondImage.asset->url,
					"alt": coalesce(secondAlt, "Imagen de portada")
				}
			)
		}
	}
`)

const mainSliderDocument = homeSliderDocuments.find((document) => document.isMain)
const fallbackSliderDocument = homeSliderDocuments[0]
const activeSliderDocument = mainSliderDocument ?? fallbackSliderDocument
const legacyMainSlideGroup = activeSliderDocument?.slideGroups?.find((group) => group.isMain)
const legacyFallbackSlideGroup = activeSliderDocument?.slideGroups?.[0]
const sourceSlides = activeSliderDocument?.slides?.length
	? activeSliderDocument.slides
	: activeSliderDocument?.heroSlides?.length
		? activeSliderDocument.heroSlides
		: legacyMainSlideGroup?.slides?.length
			? legacyMainSlideGroup.slides
			: legacyFallbackSlideGroup?.slides

const sanitySlides = sourceSlides?.filter((slide) => {
	if (slide.layout === 'split') {
		return slide.image?.src && slide.secondImage?.src
	}

	return slide.image?.src
}) ?? []

const slides = sanitySlides
---

<Layout activePage="home">
	<HeroSlider slides={slides} />

	<script>
		const scrollResetDelay = 10000;
		let scrollResetTimer: ReturnType<typeof window.setTimeout> | undefined;

		const clearScrollResetTimer = () => {
			if (!scrollResetTimer) return;

			window.clearTimeout(scrollResetTimer);
			scrollResetTimer = undefined;
		};

		const isAtPageEnd = () => {
			const scrollPosition = window.scrollY + window.innerHeight;
			const pageHeight = document.documentElement.scrollHeight;

			return scrollPosition >= pageHeight - 2;
		};

		const scheduleScrollReset = () => {
			if (scrollResetTimer || !isAtPageEnd()) return;

			scrollResetTimer = window.setTimeout(() => {
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				window.scrollTo({
					top: 0,
					behavior: prefersReducedMotion ? 'auto' : 'smooth',
				});

				scrollResetTimer = undefined;
			}, scrollResetDelay);
		};

		window.addEventListener('scroll', () => {
			if (isAtPageEnd()) {
				scheduleScrollReset();
			} else {
				clearScrollResetTimer();
			}
		}, { passive: true });

		window.addEventListener('resize', () => {
			if (isAtPageEnd()) {
				scheduleScrollReset();
			} else {
				clearScrollResetTimer();
			}
		});
	</script>
</Layout>
