---
import { sanityClient } from 'sanity:client'
import Layout from "../layouts/Layout.astro";
import "../styles/pages/about.scss";

type Project = {
    title: string
    slug: string
    previewImage?: string
}

const projects = await sanityClient.fetch<Project[]>(`
    *[
        _type == "project"
        && defined(title)
        && defined(slug.current)
        && featured == true
        && !(_id in path("drafts.**"))
    ] | order(order asc, title asc) {
        title,
        "slug": slug.current,
        "previewImage": coalesce(
            select(
            coverMedia.mediaType == "image" && defined(coverMedia.image.asset) => coverMedia.image.asset->url,
            defined(coverImage.asset) => coverImage.asset->url
            ),
            gallery[defined(image.asset)][0].image.asset->url,
            galleryBlocks[].items[][mediaType == "image" && defined(image.asset)][0].image.asset->url
        )
    }
`)
---

<Layout activePage="about">
    <section class="container-general">
        <div class="about__intro">
            <div class="about__intro-copy">
                <div class="about__logo-group">
                    <h1 class="about__logo-img">About</h1>
                    <img src="/icons/calle-icon.svg" alt="Calle" class="about__logo-logo"/>
                </div>
                <h2 class="about__intro-heading about__intro-heading--mobile">
                    <span class="about__heading-line" data-typewriter-text="Pequeñas producciones,">Pequeñas producciones,</span><br>
                    <span class="about__heading-line" data-typewriter-text="grandes ideas">grandes ideas</span>
                </h2>
            </div>
            <img src="/media/images/webp/AndreaCalle18.webp" alt="" class="about__intro-img">
            <h2 class="about__intro-heading about__intro-heading--desktop">
                <span class="about__heading-line" data-typewriter-text="Pequeñas producciones,">Pequeñas producciones,</span><br>
                <span class="about__heading-line" data-typewriter-text="grandes ideas">grandes ideas</span>
            </h2>
        </div>
        <div class="about__intro-text">
            <p class="large-text">
                Es una productora service que surge de la pasión
                por el mundo audiovisual y se desarrolla dando servicios
                de producción creativa a proyectos de moda y publicidad.
            </p>
        </div>
    </section>

    <section class="about__description-section">
        <div class="about__description">
            <div>
                <p class="large-text">01</p>
                <p class="small-text">
                    Desarrollamos grandes
                    ideas con producciones adaptadas a cada proyecto, con equipos fluidos
                    y aprovechando al máximo los recursos de cada cliente.
                </p>
            </div>

            <div>
                <p class="large-text">02</p>
                <p class="small-text">
                    Nuestra misión es abordar cada proyecto de forma personalizada, cercana
                    y mimando hasta el último detalle para conseguir contenido original y de calidad.
                </p>
            </div>

            <div>
                <p class="large-text">03</p>
                <p class="small-text">
                    Nuestra filosofía es que tanto el cliente como
                    el equipo queden satisfechos con el proceso
                    y resultado.
                </p>
            </div>
        </div>
    </section>

    <section class="container-general">
        <div class="about__clients">
            <h2>Clientes</h2>
            <div class="about__clients-list-wrap">
                <ul class="about__clients-list">
                    {projects.map((project, index) => (
                        <li
                            class="medium-text about__client-item"
                            data-preview={project.previewImage ?? ""}
                        >
                            <a href={`/projects/${project.slug}`}>
                                {project.title}{index < projects.length - 1 ? ', ' : ''}
                            </a>
                        </li>
                    ))}
                </ul>
                <div class="about__clients-preview" aria-hidden="true">
                    <img src="" alt="" loading="lazy" decoding="async" />
                </div>
            </div>
        </div>
    </section>

    <script>
        import "../js/about-intro-gsap.js";
        import "../js/about-preview-gsap.js";
    </script>
</Layout>
