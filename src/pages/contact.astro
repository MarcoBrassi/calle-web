---
import Layout from "../layouts/Layout.astro";
import "../styles/pages/contact.scss";
---

<Layout activePage="contact">
	<section class="contact-page">
		<div class="contact-page__intro container-general">
			<p class="contact-page__eyebrow">Contacto</p>
			<h1>Hablemos</h1>
		</div>

		<div class="contact-page__content container-general">
			<div class="contact-page__info">
				<p class="large-text">
					Cuéntanos qué tienes entre manos y nos pondremos en contacto contigo.
				</p>

				<a class="contact-page__email medium-text" href="mailto:hello@calleproduction.com">
					hello@calleproduction.com
				</a>
			</div>

			<form
				class="contact-form"
				action="https://formsubmit.co/hello@calleproduction.com"
				method="POST"
			>
				<input type="hidden" name="_subject" value="Nuevo mensaje desde calleproduction.com" />
				<input type="hidden" name="_template" value="table" />
				<input type="text" name="_honey" class="contact-form__hidden" tabindex="-1" autocomplete="off" />

				<div class="contact-form__row">
					<label for="name">Nombre</label>
					<input id="name" name="Nombre" type="text" autocomplete="given-name" required />
				</div>

				<div class="contact-form__row">
					<label for="surname">Apellidos</label>
					<input id="surname" name="Apellidos" type="text" autocomplete="family-name" required />
				</div>

				<div class="contact-form__row">
					<label for="phone">Teléfono</label>
					<input id="phone" name="Teléfono" type="tel" autocomplete="tel" required />
				</div>

				<div class="contact-form__row">
					<label for="email">Email</label>
					<input id="email" name="email" type="email" autocomplete="email" required />
				</div>

				<div class="contact-form__row contact-form__row--full">
					<label for="comments">Comentarios</label>
					<textarea id="comments" name="Comentarios" rows="6" required></textarea>
				</div>

				<button class="contact-form__submit" type="submit">Enviar</button>
			</form>
		</div>
	</section>
</Layout>
