---
import "../../styles/galleries/gallery_4col.scss";
import { sanityImageSrcSet } from "../../utils/sanityImages";

type GalleryItem = {
    type: "image" | "video";
    src: string;
    alt?: string;
};

interface Props {
    items?: GalleryItem[];
    title?: string;
    campaign?: string;
    services?: string[];
    description?: string;
}

const {
    items = [],
    title = "",
    campaign = "",
    services = [],
    description = "",
} = Astro.props;

const servicesText = services.join(", ");
const coverImageSizes = "(max-width: 768px) calc(100vw - 2rem), min(calc(100vw - 2rem), 98rem)";
const gridImageSizes = "(max-width: 768px) calc(100vw - 2rem), (max-width: 1024px) calc((100vw - 3rem) / 2), min(calc((100vw - 5rem) / 4), 24.25rem)";
---

<section class="gallery4col">
    <header class="project-info project-info--overlay">
        {title && <h2>{title}</h2>}
        {campaign && <p class="project-info__campaign">{campaign}</p>}
        <div class="project-info__details">
            {servicesText && <p class="project-info__services">{servicesText}</p>}
            {description && <p class="project-info__description">{description}</p>}
        </div>
    </header>

    <div class="gallery4col__grid">
        {
        items.map((item, index) => (
            <article class={`gallery4col__item ${index === 0 ? "gallery4col__item--cover" : ""}`}>
                {
                    item.type === "video" ? (
                    <video autoplay muted loop playsinline controls preload="metadata">
                        <source src={item.src} type="video/mp4" />
                        Tu navegador no puede reproducir este vídeo.
                    </video>
                    ) : (
                    <img
                        src={item.src}
                        srcset={sanityImageSrcSet(item.src, {quality: index === 0 ? 72 : 76})}
                        sizes={index === 0 ? coverImageSizes : gridImageSizes}
                        alt={item.alt || ""}
                        loading={index === 0 ? "eager" : "lazy"}
                        decoding="async"
                        fetchpriority={index === 0 ? "high" : "auto"}
                    />
                    )
                }
            </article>
        ))
        }
    </div>
</section>
