---
import "../../styles/galleries/gallery_2col.scss";
import { sanityImageSrcSet } from "../../utils/sanityImages";

type GalleryItem = {
    type: "image" | "video";
    src: string;
    alt?: string;
};

interface Props {
    items?: GalleryItem[];
    title?: string;
    campaign?: string;
    services?: string[];
    description?: string;
}

const {
    items = [],
    title = "",
    campaign = "",
    services = [],
    description = "",
} = Astro.props;

const servicesText = services.join(", ");
const columns = [
    items.filter((_, index) => index % 2 === 0),
    items.filter((_, index) => index % 2 !== 0),
];
const imageSizes = "(max-width: 768px) calc(100vw - 2rem), min(calc((100vw - 3rem) / 2), 49.5rem)";
---

<section class="gallery2col">
    <header class="project-info project-info--overlay">
        {title && <h2>{title}</h2>}
        {campaign && <p class="project-info__campaign">{campaign}</p>}
        <div class="project-info__details">
            {servicesText && <p class="project-info__services">{servicesText}</p>}
            {description && <p class="project-info__description">{description}</p>}
        </div>
    </header>

    <div class="project-gallery project-gallery--two-columns">
        {
        columns.map((column, columnIndex) => (
            <div class="project-gallery__column">
                {
                column.map((item, itemIndex) => {
                    const originalIndex = itemIndex * 2 + columnIndex;

                    return (
                        <article class={`project-gallery__item ${originalIndex === 0 ? "project-gallery__item--cover" : ""}`}>
                        {
                            item.type === "video" ? (
                            <video autoplay muted loop playsinline controls preload="metadata">
                                <source src={item.src} type="video/mp4" />
                                Tu navegador no puede reproducir este vídeo.
                            </video>
                            ) : (
                            <img
                                src={item.src}
                                srcset={sanityImageSrcSet(item.src, {quality: originalIndex === 0 ? 72 : 76})}
                                sizes={imageSizes}
                                alt={item.alt || ""}
                                loading={originalIndex === 0 ? "eager" : "lazy"}
                                decoding="async"
                                fetchpriority={originalIndex === 0 ? "high" : "auto"}
                            />
                            )
                        }
                        </article>
                    );
                })
                }
            </div>
        ))
        }
    </div>
</section>
