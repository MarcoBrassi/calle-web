---
import "../../styles/galleries/gallery_mosaic.scss";

type GalleryItem = {
    type: "image" | "video";
    src: string;
    alt?: string;
    size?: "normal" | "tall" | "wide" | "large";
};

type GalleryBlock = {
    blockType: "stackedFull" | "threeColumns" | "dynamicTwoColumns" | "fullWidth";
    title?: string;
    items?: GalleryItem[];
};

interface Props {
    coverMedia?: GalleryItem;
    blocks?: GalleryBlock[];
    title?: string;
    campaign?: string;
    services?: string[];
    description?: string;
}

const {
    coverMedia,
    blocks = [],
    title = "",
    campaign = "",
    services = [],
    description = "",
} = Astro.props;

const servicesText = services.join(", ");
---

<section class="gallery-mosaic">
    <header class="project-info project-info--overlay">
        {title && <h2>{title}</h2>}
        {campaign && <p class="project-info__campaign">{campaign}</p>}
        {servicesText && <p class="project-info__services">{servicesText}</p>}
        {description && <p class="project-info__description">{description}</p>}
    </header>

    {coverMedia?.src && (
        <article class="gallery-mosaic__cover">
            {
                coverMedia.type === "video" ? (
                <video autoplay muted loop playsinline controls preload="metadata">
                    <source src={coverMedia.src} type="video/mp4" />
                    Tu navegador no puede reproducir este vídeo.
                </video>
                ) : (
                <img src={coverMedia.src} alt={coverMedia.alt || title} />
                )
            }
        </article>
    )}

    <div class="gallery-mosaic__blocks">
        {
        blocks.map((block) => (
            <section class={`gallery-mosaic__block gallery-mosaic__block--${block.blockType}`}>
                {
                block.items?.map((item) => (
                    <article class={`gallery-mosaic__item gallery-mosaic__item--${item.size || "normal"}`}>
                        {
                            item.type === "video" ? (
                            <video autoplay muted loop playsinline controls preload="metadata">
                                <source src={item.src} type="video/mp4" />
                                Tu navegador no puede reproducir este vídeo.
                            </video>
                            ) : (
                            <img src={item.src} alt={item.alt || ""} />
                            )
                        }
                    </article>
                ))
                }
            </section>
        ))
        }
    </div>
</section>
