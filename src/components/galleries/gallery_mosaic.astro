---
import "../../styles/galleries/gallery_mosaic.scss";
import { sanityImageSrcSet } from "../../utils/sanityImages";

type GalleryItem = {
    type: "image" | "video";
    src: string;
    alt?: string;
    size?: "normal" | "tall" | "wide" | "large";
    isCover?: boolean;
};

type GalleryBlock = {
    blockType: "stackedFull" | "threeColumns" | "dynamicTwoColumns" | "fullWidth" | "squareTwoColumns";
    title?: string;
    items?: GalleryItem[];
};

interface Props {
    blocks?: GalleryBlock[];
    title?: string;
    campaign?: string;
    services?: string[];
    description?: string;
}

const {
    blocks = [],
    title = "",
    campaign = "",
    services = [],
    description = "",
} = Astro.props;

const servicesText = services.join(", ");
let itemIndex = 0;
const indexedBlocks = blocks.map((block) => ({
    ...block,
    items: block.items?.map((item) => ({
        ...item,
        isCover: itemIndex++ === 0,
    })),
}));

const getMosaicImageSizes = (blockType: GalleryBlock["blockType"], size?: GalleryItem["size"]) => {
    if (blockType === "threeColumns") {
        return "(max-width: 768px) calc(100vw - 2rem), min(calc((100vw - 4rem) / 3), 32rem)";
    }

    if (blockType === "squareTwoColumns") {
        return "(max-width: 768px) calc(100vw - 2rem), min(calc((100vw - 3rem) / 2), 49.5rem)";
    }

    if (blockType === "dynamicTwoColumns") {
        return size === "wide" || size === "large"
            ? "(max-width: 768px) calc(100vw - 2rem), min(calc(100vw - 2rem), 98rem)"
            : "(max-width: 768px) calc(100vw - 2rem), min(calc((100vw - 3rem) / 2), 49.5rem)";
    }

    return "(max-width: 768px) calc(100vw - 2rem), min(calc(100vw - 2rem), 98rem)";
};
---

<section class="gallery-mosaic">
    <header class="project-info project-info--overlay">
        {title && <h2>{title}</h2>}
        {campaign && <p class="project-info__campaign">{campaign}</p>}
        <div class="project-info__details">
            {servicesText && <p class="project-info__services">{servicesText}</p>}
            {description && <p class="project-info__description">{description}</p>}
        </div>
    </header>

    <div class="gallery-mosaic__blocks">
        {
        indexedBlocks.map((block) => (
            <section class={`gallery-mosaic__block gallery-mosaic__block--${block.blockType}`}>
                {
                block.items?.map((item) => (
                    <article class={`gallery-mosaic__item gallery-mosaic__item--${item.size || "normal"} ${item.isCover ? "gallery-mosaic__item--cover" : ""}`}>
                        {
                            item.type === "video" ? (
                            <video autoplay muted loop playsinline controls preload="metadata">
                                <source src={item.src} type="video/mp4" />
                                Tu navegador no puede reproducir este video.
                            </video>
                            ) : (
                            <img
                                src={item.src}
                                srcset={sanityImageSrcSet(item.src, {quality: item.isCover ? 72 : 76})}
                                sizes={getMosaicImageSizes(block.blockType, item.size)}
                                alt={item.alt || ""}
                                loading={item.isCover ? "eager" : "lazy"}
                                decoding="async"
                                fetchpriority={item.isCover ? "high" : "auto"}
                            />
                            )
                        }
                    </article>
                ))
                }
            </section>
        ))
        }
    </div>
</section>
